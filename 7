#include <iostream> 
#include <vector> 
using namespace std; 
vector<int> filterEven(const vector<int>& data) 
{ 
vector<int> result; 
for (int num : data) 
{ 
if (num % 2 == 0) 
{ 
result.push_back(num); 
} 
} 
return result; 
} 
vector<int> squareNumbers(const vector<int>& data) 
{ 
vector<int> result; 
for (int num : data) 
{ 
result.push_back(num * num); 
} 
return result; 
} 
int main() 
{ 
vector<int> data = {1, 2, 3, 4, 5, 6}; 
vector<int> evenNumbers = filterEven(data); 
vector<int> squaredNumbers = squareNumbers(evenNumbers); 
cout << "Початковий список: "; 
for (int num : data) 
{ 
cout << num << " "; 
} 
cout << endl; 
cout << "Результат pipeline: "; 
for (int num : squaredNumbers) 
{ 
cout << num << " "; 
} 
return 0; 
} 
