#include <iostream> 
#include <vector> 
#include <functional> 
using namespace std; 
using Step = function<vector<int>(const vector<int>&)>; 
vector<int> pipeline(const vector<int>& data, const vector<Step>& steps) 
{ 
vector<int> result = data; 
for (const Step& step : steps) 
{ 
result = step(result); 
} 
return result; 
} 
vector<int> filterEven(const vector<int>& xs) 
{ 
vector<int> result; 
for (int x : xs) 
{ 
if (x % 2 == 0) 
{ 
result.push_back(x); 
} 
} 
return result; 
} 
vector<int> squareNumbers(const vector<int>& xs) 
{ 
vector<int> result; 
for (int x : xs) 
{ 
result.push_back(x * x); 
} 
return result; 
} 
int main() 
{ 
vector<int> data = {1, 2, 3, 4, 5, 6}; 
vector<Step> steps = { 
filterEven, 
squareNumbers 
}; 
vector<int> result = pipeline(data, steps); 
cout << "Початкові дані: "; 
for (int x : data) 
{ 
cout << x << " "; 
} 
cout << endl; 
cout << "Результат pipeline: "; 
for (int x : result) 
{ 
cout << x << " "; 
} 
return 0; 
} 
